<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.uqi.mcp</string>
  <key>ProgramArguments</key>
  <array>
    <string>__VENV__/bin/python</string>
    <string>__UQI_DIR__/src/mcp_server.py</string>
    <string>--host</string>
    <string>0.0.0.0</string>
    <string>--port</string>
    <string>8765</string>
    <string>--transport</string>
    <string>sse</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__UQI_DIR__</string>
  <key>StandardOutPath</key>
  <string>__UQI_DIR__/logs/mcp.log</string>
  <key>StandardErrorPath</key>
  <string>__UQI_DIR__/logs/mcp.log</string>
  <key>KeepAlive</key>
  <true/>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
