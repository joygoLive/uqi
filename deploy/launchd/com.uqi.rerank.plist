<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.uqi.rerank</string>
  <key>ProgramArguments</key>
  <array>
    <string>__VENV__/bin/python</string>
    <string>__UQI_DIR__/deploy/rerank_server.py</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>UQI_RERANK_DEVICE</key>
    <string>cpu</string>
  </dict>
  <key>WorkingDirectory</key>
  <string>__UQI_DIR__</string>
  <key>StandardOutPath</key>
  <string>__UQI_DIR__/logs/rerank.log</string>
  <key>StandardErrorPath</key>
  <string>__UQI_DIR__/logs/rerank.log</string>
  <key>KeepAlive</key>
  <true/>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
